{
  "name": "banana-drum",
  "version": "0.0.1",
  "description": "Music sequencer web-app designed for samba bands",
  "repository": {
    "type": "git",
    "url": "https://github.com/mooseling/BananaDrum.git"
  },
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/react": "17.0.37",
    "@types/react-dom": "17.0.11",
    "@typescript-eslint/eslint-plugin": "6.7.5",
    "@typescript-eslint/parser": "6.7.5",
    "eslint": "8.51.0",
    "eslint-plugin-react": "7.33.2",
    "typescript": "5.8.3"
  },
  "scripts": {
    "dev": "npm run dev -w bananadrum-webapp",
    "build": "npm run build -w bananadrum-webapp",
    "preview": "npm run preview -w bananadrum-webapp",
    "test": "npm run test -w bananadrum-core",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint ."
  },
  "workspaces": [
    "packages/bananadrum-core",
    "packages/bananadrum-player",
    "packages/bananadrum-ui",
    "packages/bananadrum-webapp"
  ],
  "dependencies": {
    "big-integer": "1.6.52"
  }
}
